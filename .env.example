# 服务配置
PORT=3000
NODE_ENV=development

# 数据库配置 (GaussDB/openGauss)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=your_user
DB_PASSWORD=your_password
DB_NAME=aml_db
DB_MAX_CONNECTIONS=20

# AW智能体平台配置
AW_AGENT_BASE_URL=http://your-aw-platform-url
AW_API_KEY=your-api-key
AW_AGENT_ID=your-agent-id
AW_TIMEOUT_MS=60000

# 重试配置
RETRY_MAX=3
RETRY_INTERVAL_MS=30000

# 下游回调配置
DOWNSTREAM_CALLBACK_URL=http://your-downstream-callback-url
CALLBACK_TIMEOUT_MS=10000

# 安全配置
ALLOWED_API_KEYS=key1,key2
IP_WHITELIST=
SIGNATURE_SECRET=your-signature-secret
