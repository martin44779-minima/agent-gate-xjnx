# 接口限流（针对 /api 路径的全局限流）
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# 安全配置（AUTH_ENABLED=false 时关闭所有认证，内网部署推荐关闭）
